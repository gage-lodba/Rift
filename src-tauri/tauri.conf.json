{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Rift",
  "version": "0.1.0",
  "identifier": "dev.jerimiah.rift",
  "build": {
    "frontendDist": "../dist",
    "beforeDevCommand": {
      "cwd": "../ui",
      "script": "trunk build"
    },
    "beforeBuildCommand": {
      "cwd": "../ui",
      "script": "trunk build --release"
    }
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Rift",
        "label": "main",
        "width": 1160,
        "height": 740,
        "minWidth": 940,
        "minHeight": 620,
        "decorations": false,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"],
    "category": "Music",
    "shortDescription": "An ad-free YouTube Music player"
  }
}
